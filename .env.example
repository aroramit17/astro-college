SOURCE_MODE=json
INPUT_PATH=./data/sample-freelancers.json
SEARCH_CONFIG_PATH=./config/search-config.json
OUTPUT_DIR=./output

# Set to true to push qualified profiles into Google Drive.
ENABLE_GOOGLE_DRIVE=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Reserved for official Upwork API access.
UPWORK_API_BASE_URL=https://www.upwork.com/api
UPWORK_ACCESS_TOKEN=
UPWORK_SEARCH_SAVED_QUERY=
